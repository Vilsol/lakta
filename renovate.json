{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices"
  ],
  "postUpdateOptions": [
    "gomodMassage",
    "gomodTidy",
    "gomodUpdateImportPaths"
  ],
  "automerge": true,
  "postUpgradeTasks": {
    "commands": [
      "GOWORK=off go list -m all | awk '{print $1}' | LC_ALL=C sort > core-deps.golden"
    ],
    "fileFilters": [
      "core-deps.golden"
    ],
    "executionMode": "branch"
  },
  "packageRules": [
    {
      "description": "Group non-major Go updates across the root and examples modules into a single PR",
      "matchManagers": [
        "gomod"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch",
        "digest"
      ],
      "groupName": "go module dependencies"
    }
  ]
}
